# === App/Server ===
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=changeme-super-secret

# Regras de reserva e preço
RESERVATION_TTL_MIN=15
PRICE_CENTS=5500

# === Postgres (Supabase) ===
POSTGRES_URL=postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require

# === Mercado Pago (TEST) ===
MP_ACCESS_TOKEN=TEST-REPLACE-ME

# Notification Center
NOTIFICATION_CENTER_ENABLED=true
NOTIFICATION_TEST_MODE=true
NOTIFICATION_ALLOW_REAL_RECIPIENTS=false
NOTIFICATION_TEST_WHATSAPP_TO=
NOTIFICATION_ADMIN_TEST_CUSTOM_RECIPIENTS_ENABLED=false
NOTIFICATION_ADMIN_TEST_ALLOWED_RECIPIENTS=
