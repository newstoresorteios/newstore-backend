# === App/Server ===
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=changeme-super-secret

# Regras de reserva e preço
RESERVATION_TTL_MIN=15
PRICE_CENTS=5500

# Pre-autorizacao de numeros cativos
CAPTIVE_PREAUTH_ENABLED=true
CAPTIVE_PREAUTH_EXPIRY_SCAN_ENABLED=true
CAPTIVE_PREAUTH_EXPIRY_SCAN_INTERVAL_MS=300000
CAPTIVE_PREAUTH_EXPIRES_HOURS=12
CAPTIVE_PREAUTH_CHARGE_ON_AUTHORIZE_ENABLED=true
# Regra oficial: sem resposta no prazo, autoriza e cobra automaticamente.
CAPTIVE_PREAUTH_AUTO_APPROVE_ON_EXPIRY_ENABLED=true
# Obrigatório para autoaprovação: timestamp ISO do início do novo comportamento.
CAPTIVE_PREAUTH_AUTO_APPROVE_EFFECTIVE_FROM=

# === Postgres (Supabase) ===
POSTGRES_URL=postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require

# TrayAdapter (Backend -> TrayAdapter -> Tray)
TRAY_ADAPTER_URL=
TRAY_ADAPTER_TOKEN=

# === Mercado Pago (TEST) ===
MP_ACCESS_TOKEN=TEST-REPLACE-ME

# Notification Center
NOTIFICATION_CENTER_ENABLED=true
NOTIFICATION_TEST_MODE=true
NOTIFICATION_ALLOW_REAL_RECIPIENTS=false
NOTIFICATION_TEST_WHATSAPP_TO=
NOTIFICATION_ADMIN_TEST_CUSTOM_RECIPIENTS_ENABLED=false
NOTIFICATION_ADMIN_TEST_ALLOWED_RECIPIENTS=
NOTIFICATION_WHATSAPP_REQUIRE_CONSENT=true
NOTIFICATION_WHATSAPP_ALLOW_UNLINKED_PHONE=false
NOTIFICATION_WEBHOOK_SECRET=

# Brevo WhatsApp
BREVO_API_KEY=
BREVO_WHATSAPP_ENABLED=false
BREVO_WHATSAPP_SENDER_NUMBER=
BREVO_WHATSAPP_GENERIC_TEST_TEMPLATE_ID=
BREVO_WHATSAPP_CAPTIVE_AUTH_TEMPLATE_ID=
BREVO_WHATSAPP_BASE_URL=https://api.brevo.com/v3
BREVO_WHATSAPP_TIMEOUT_MS=15000
NOTIFICATION_WHATSAPP_AUTOMATION_ENABLED=false
NOTIFICATION_WHATSAPP_CAMPAIGN_ENABLED=false
NOTIFICATION_WHATSAPP_FALLBACK_ENABLED=false

# Email automation (Engine -> Backend internal event -> SMTP)
NOTIFICATION_EMAIL_AUTOMATION_ENABLED=false
PUSH_INTERNAL_EVENTS_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=contato@newstorerj.com.br
SMTP_FROM_NAME=New Store Sorteios
SMTP_REPLY_TO=contato@newstorerj.com.br

# Web Push: teste restrito a uma conta e uma subscription
PUSH_ENABLED=true
PUSH_MODE=single_device_test
PUSH_TEST_ONLY=true
PUSH_TEST_PHONE_LABEL=43998640480
PUSH_TEST_SUBSCRIPTION_ID=
PUSH_TEST_SUBSCRIPTION_IDS=
PUSH_TEST_MAX_DEVICES=2
PUSH_TEST_ALLOWED_USER_ID=416
PUSH_TEST_ALLOWED_EMAIL=
PUSH_TEST_SETUP_CODE=
PUSH_HIDE_FOR_UNAUTHORIZED_USERS=true
PUSH_ALLOW_PUBLIC_SUBSCRIBE=false
PUSH_ALLOW_DB_RECIPIENT_LOOKUP=false
PUSH_ALLOW_AUDIENCE=false
PUSH_ALLOW_ENGINE_EVENTS=false
PUSH_ALLOW_ADMIN_MASS_SEND=false
PUSH_ALLOW_CAMPAIGNS=false
PUSH_ALLOW_PRODUCTION_SEND=false
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:suporte@newstore.com.br
INTERNAL_ENGINE_TOKEN=
